#!/usr/bin/env bash
# Enforces branch naming: <issue-code>-<slug> or <slug> (kebab-case, no slashes, no uppercase)
# Valid: a1-supabase-setup, c3-db-service, organize-docs, main
# Invalid: feat/thing, Feature/x, CAPS, feat-A1-thing

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [[ "$branch" == "main" ]]; then
  exit 0
fi

if ! [[ "$branch" =~ ^[a-z][a-z0-9-]*$ ]]; then
  echo ""
  echo "  Branch name rejected: '$branch'"
  echo ""
  echo "  Branch names must be lowercase kebab-case with no slashes."
  echo "  For issue branches:     <issue-code>-<slug>   e.g. a1-supabase-setup"
  echo "  For non-issue branches: <slug>                e.g. organize-docs"
  echo ""
  exit 1
fi
